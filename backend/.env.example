# Copy this to .env and fill the values
PORT=3000
NODE_ENV=development

# Either provide SUPABASE_ANON_KEY to use the Supabase JS client
# or provide SUPABASE_DB_URL (Postgres connection string) for direct PG access.
# SUPABASE_URL is still used by some parts of the app (e.g., auth URLs).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=

# Example Postgres connection string (set this when you only have DB URL):
# postgres://<db_user>:<db_pass>@db.<region>.supabase.co:5432/postgres
SUPABASE_DB_URL=
